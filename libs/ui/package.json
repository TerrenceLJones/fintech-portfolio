{
  "name": "@fintech-portfolio/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Clearline design system React component library, styled with Tailwind CSS v4 against @fintech-portfolio/design-tokens' --cl-* tokens, with Radix (radix-ui) backing the interactive/accessible primitives.",
  "main": "src/index.ts",
  "scripts": {
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test-storybook": "vitest run --project=storybook",
    "build": "vite build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.18.1"
  },
  "dependencies": {
    "@fintech-portfolio/design-tokens": "workspace:*",
    "@fintech-portfolio/icons": "workspace:*",
    "radix-ui": "^1.6.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-vitest": "^10.4.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "chromatic": "^18.0.0",
    "playwright": "^1.61.1",
    "react-router": "^7.18.1",
    "vitest": "^4.1.9"
  },
  "metadata": {
    "package_type": "shared",
    "app": "clearline-web",
    "source_of_truth": "Built tier-by-tier (foundations -> atoms -> molecules -> organisms -> decorators); see specs/epics/clearline-web/EPIC-CW-000.yaml and specs/user-stories/clearline-web/US-CW-022..026.yaml for the traceability record."
  }
}
