{
  "name": "@clearline/mock-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Platform-wide MSW v2 mock backend convention: stateful TypeScript services hold the invariants, MSW handlers are thin HTTP/WebSocket adapters in front of them. See TDR-PLATFORM-001 > technology_decisions.shared_mock_backend_strategy.",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./browser": "./src/browser.ts",
    "./server": "./src/server.ts",
    "./fixtures": "./src/fixtures/index.ts",
    "./test-factories": "./src/fixtures/test-factories.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsc"
  },
  "dependencies": {
    "@clearline/contracts": "workspace:*",
    "@clearline/domain-auth": "workspace:*",
    "@clearline/domain-cards": "workspace:*",
    "@clearline/domain-integrations": "workspace:*",
    "@clearline/domain-org-security": "workspace:*",
    "@clearline/domain-expenses": "workspace:*",
    "@clearline/domain-onboarding": "workspace:*",
    "@clearline/domain-payments": "workspace:*",
    "@clearline/domain-reconciliation": "workspace:*",
    "@clearline/domain-budgets": "workspace:*",
    "@clearline/domain-profile": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "msw": "^2.14.6"
  },
  "metadata": {
    "package_type": "shared",
    "platform_baseline_tdr": "TDR-PLATFORM-001",
    "architectural_pattern": "services-first, handlers-second",
    "structural_convention": "src/{services,handlers,fixtures}/ + src/browser.ts (dev/Storybook) + src/server.ts (Vitest/Playwright)",
    "contract_testing": "No Pact / consumer-driven contract testing — see TDR-PLATFORM-001 ADR-006 reference and libs/contracts."
  }
}
