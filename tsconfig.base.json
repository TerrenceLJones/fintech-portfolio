{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "composite": true,
    "incremental": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@clearline/design-tokens": ["libs/design-tokens/src/index.ts"],
      "@clearline/demo-beacon": ["libs/demo-beacon/src/index.ts"],
      "@clearline/mock-backend": ["libs/mock-backend/src/index.ts"],
      "@clearline/mock-backend/browser": ["libs/mock-backend/src/browser.ts"],
      "@clearline/mock-backend/server": ["libs/mock-backend/src/server.ts"],
      "@clearline/mock-backend/fixtures": ["libs/mock-backend/src/fixtures/index.ts"],
      "@clearline/mock-backend/test-factories": [
        "libs/mock-backend/src/fixtures/test-factories.ts"
      ],
      "@clearline/contracts": ["libs/contracts/src/index.ts"],
      "@clearline/icons": ["libs/icons/src/index.ts"],
      "@clearline/ui": ["libs/ui/src/index.ts"],
      "@clearline/money": ["libs/util/money/src/index.ts"],
      "@clearline/domain-auth": ["libs/domain/auth/src/index.ts"],
      "@clearline/data-access-auth": ["libs/data-access/auth/src/index.ts"],
      "@clearline/data-access-approvals": ["libs/data-access/approvals/src/index.ts"],
      "@clearline/domain-onboarding": ["libs/domain/onboarding/src/index.ts"],
      "@clearline/data-access-onboarding": ["libs/data-access/onboarding/src/index.ts"],
      "@clearline/domain-payments": ["libs/domain/payments/src/index.ts"],
      "@clearline/data-access-payments": ["libs/data-access/payments/src/index.ts"],
      "@clearline/domain-cards": ["libs/domain/cards/src/index.ts"],
      "@clearline/data-access-cards": ["libs/data-access/cards/src/index.ts"],
      "@clearline/domain-expenses": ["libs/domain/expenses/src/index.ts"],
      "@clearline/data-access-expenses": ["libs/data-access/expenses/src/index.ts"],
      "@clearline/data-access-analytics": ["libs/data-access/analytics/src/index.ts"],
      "@clearline/domain-reconciliation": ["libs/domain/reconciliation/src/index.ts"],
      "@clearline/data-access-reconciliation": ["libs/data-access/reconciliation/src/index.ts"],
      "@clearline/domain-budgets": ["libs/domain/budgets/src/index.ts"],
      "@clearline/data-access-budgets": ["libs/data-access/budgets/src/index.ts"],
      "@clearline/data-access-audit": ["libs/data-access/audit/src/index.ts"],
      "@clearline/data-access-team": ["libs/data-access/team/src/index.ts"],
      "@clearline/data-access-settings": ["libs/data-access/settings/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}
