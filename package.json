{
  "name": "@fintech-portfolio/source",
  "version": "0.1.0",
  "private": true,
  "description": "B2B spend management / payments frontend demo portfolio (web-only). First app: clearline-web.",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "nx run-many --target=dev --all",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "type-check": "nx run-many --target=type-check --all",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .gitignore",
    "graph": "nx graph"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@nx/js": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "nx": "23.0.1",
    "prettier": "^3.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.1",
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "monorepo",
    "fintech-portfolio",
    "typescript",
    "nx",
    "pnpm"
  ],
  "author": "Terrence L. Jones",
  "metadata": {
