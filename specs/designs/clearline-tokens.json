{
  "$name": "Clearline Design Tokens",
  "$description": "Machine-readable token manifest for the Clearline spend platform. One source of truth feeding Figma Variables, React theming and the icon registry (clearline-icons.js). Tiers: primitive -> semantic -> component. Every status pairs a hue with a distinct shape, icon and text label so no meaning is carried by colour alone.",
  "$version": "2.0.0",
  "themes": ["light", "dark"],

  "primitive": {
    "neutral": {
      "0": "#ffffff",
      "50": "#f7f8fa",
      "100": "#eef0f3",
      "200": "#e1e5ea",
      "300": "#c8cdd6",
      "400": "#9aa1ad",
      "500": "#6f7785",
      "600": "#4c545f",
      "700": "#333942",
      "800": "#1d2128",
      "900": "#0b0d11"
    },
    "indigo": {
      "50": "#ecf1fe",
      "100": "#c9d8fc",
      "300": "#7da0f9",
      "500": "#3b6cf6",
      "600": "#2f5ce0",
      "800": "#1d3a9e"
    },
    "green": { "50": "#e4f3eb", "300": "#a7dabd", "600": "#15805a" },
    "red": { "50": "#fbeae8", "300": "#eaa39b", "600": "#c0392b", "700": "#b3231b" },
    "amber": { "50": "#fbf0db", "300": "#ecc77f", "600": "#9a5b00" },
    "teal": { "50": "#e3f3f7", "300": "#7fc6d6", "600": "#0e6e8c" },
    "violet": { "50": "#efebfd", "300": "#a48bf5", "600": "#5a3ec8" }
  },

  "semantic": {
    "$note": "What components consume. Each token resolves per-theme; primitives are never referenced directly by components.",
    "bg": { "cssVar": "--cl-bg", "role": "App background", "light": "#f5f6f8", "dark": "#0b0d11" },
    "surface": {
      "cssVar": "--cl-surface",
      "role": "Card / panel surface",
      "light": "#ffffff",
      "dark": "#14171d"
    },
    "surface-2": {
      "cssVar": "--cl-surface-2",
      "role": "Inset surface, toggles, chips",
      "light": "#f0f2f5",
      "dark": "#1b1f27"
    },
    "inset": {
      "cssVar": "--cl-inset",
      "role": "Recessed wells, table headers",
      "light": "#f7f8fa",
      "dark": "#11141a"
    },
    "border": {
      "cssVar": "--cl-border",
      "role": "Default hairline border",
      "light": "#e4e7eb",
      "dark": "#272c35"
    },
    "border-2": {
      "cssVar": "--cl-border-2",
      "role": "Stronger border, inputs",
      "light": "#d3d8df",
      "dark": "#363c47"
    },
    "text": {
      "cssVar": "--cl-text",
      "role": "Primary copy",
      "light": "#161a20",
      "dark": "#e8ebf0"
    },
    "text-2": {
      "cssVar": "--cl-text-2",
      "role": "Secondary copy",
      "light": "#586070",
      "dark": "#a0a8b5"
    },
    "text-3": {
      "cssVar": "--cl-text-3",
      "role": "Tertiary / muted labels",
      "light": "#8b929e",
      "dark": "#6c7480"
    },
    "accent": {
      "cssVar": "--cl-accent",
      "role": "Primary actions, links, focus",
      "light": "#3b6cf6",
      "dark": "#5b85f8"
    },
    "accent-2": {
      "cssVar": "--cl-accent-2",
      "role": "Accent hover / pressed",
      "light": "#2f5ce0",
      "dark": "#7398fa"
    },
    "accent-weak": {
      "cssVar": "--cl-accent-weak",
      "role": "Accent tint background",
      "light": "#ecf1fe",
      "dark": "#172240"
    },
    "accent-text": {
      "cssVar": "--cl-accent-text",
      "role": "Accent text on tint",
      "light": "#2a55cc",
      "dark": "#9fb8fb"
    },
    "pos": {
      "cssVar": "--cl-pos",
      "role": "Credits, gains, matched",
      "light": "#15805a",
      "dark": "#4ec78a"
    },
    "pos-weak": {
      "cssVar": "--cl-pos-weak",
      "role": "Positive tint background",
      "light": "#e4f3eb",
      "dark": "#11271d"
    },
    "neg": {
      "cssVar": "--cl-neg",
      "role": "Debits, declines, over-limit",
      "light": "#c0392b",
      "dark": "#f1746c"
    },
    "neg-weak": {
      "cssVar": "--cl-neg-weak",
      "role": "Negative tint background",
      "light": "#fbeae8",
      "dark": "#2a1411"
    },
    "pending": {
      "cssVar": "--cl-pending",
      "role": "In-flight, awaiting action",
      "light": "#2a55cc",
      "dark": "#9fb8fb"
    },
    "pending-weak": {
      "cssVar": "--cl-pending-weak",
      "role": "Pending tint background",
      "light": "#ecf1fe",
      "dark": "#172240"
    },
    "warn": {
      "cssVar": "--cl-warn",
      "role": "Policy flags, 80% budget",
      "light": "#9a5b00",
      "dark": "#e2ab43"
    },
    "warn-weak": {
      "cssVar": "--cl-warn-weak",
      "role": "Warning tint background",
      "light": "#fbf0db",
      "dark": "#291f0e"
    },
    "crit": {
      "cssVar": "--cl-crit",
      "role": "Over budget, fatal errors",
      "light": "#b3231b",
      "dark": "#f1746c"
    },
    "crit-weak": {
      "cssVar": "--cl-crit-weak",
      "role": "Critical tint background",
      "light": "#fce9e7",
      "dark": "#2a1411"
    },
    "paid": {
      "cssVar": "--cl-paid",
      "role": "Settled / paid state",
      "light": "#0e6e8c",
      "dark": "#43b8d6"
    },
    "paid-weak": {
      "cssVar": "--cl-paid-weak",
      "role": "Paid tint background",
      "light": "#e3f3f7",
      "dark": "#0c2730"
    },
    "recon": {
      "cssVar": "--cl-recon",
      "role": "Reconciled state",
      "light": "#5a3ec8",
      "dark": "#a48bf5"
    },
    "recon-weak": {
      "cssVar": "--cl-recon-weak",
      "role": "Reconciled tint background",
      "light": "#efebfd",
      "dark": "#1d1640"
    },
    "focus": { "cssVar": "--cl-focus", "role": "Focus ring", "light": "#3b6cf6", "dark": "#5b85f8" }
  },

  "signal": {
    "$note": "Accessibility contract — every signal is colour + shape + icon + label. Removing hue leaves each distinguishable by glyph and shape. Passes the grayscale test.",
    "positive": {
      "token": "color-status-positive",
      "label": "Positive",
      "color": "--cl-pos",
      "tint": "--cl-pos-weak",
      "icon": "check",
      "shape": "check",
      "treatment": "solid"
    },
    "negative": {
      "token": "color-status-negative",
      "label": "Negative",
      "color": "--cl-neg",
      "tint": "--cl-neg-weak",
      "icon": "x-circle",
      "shape": "circle",
      "treatment": "solid"
    },
    "warning": {
      "token": "color-status-warning",
      "label": "Warning",
      "color": "--cl-warn",
      "tint": "--cl-warn-weak",
      "icon": "triangle-alert",
      "shape": "triangle",
      "treatment": "outlined"
    },
    "critical": {
      "token": "color-status-critical",
      "label": "Critical",
      "color": "--cl-crit",
      "tint": "--cl-crit-weak",
      "icon": "octagon-alert",
      "shape": "octagon",
      "treatment": "solid"
    },
    "info": {
      "token": "color-status-info",
      "label": "Info",
      "color": "--cl-accent",
      "tint": "--cl-accent-weak",
      "icon": "info",
      "shape": "circle",
      "treatment": "ghost"
    }
  },

  "workflow": {
    "$note": "Expense / payment lifecycle. Each state is a StatusBadge with a distinct glyph + label + semantic colour. Order is the happy path; terminal states are separated.",
    "draft": {
      "label": "Draft",
      "color": "--cl-text-2",
      "tint": "--cl-surface-2",
      "icon": "pencil",
      "treatment": "outlined"
    },
    "pending-l1": {
      "label": "Pending L1",
      "color": "--cl-pending",
      "tint": "--cl-pending-weak",
      "icon": "clock",
      "treatment": "solid"
    },
    "pending-l2": {
      "label": "Pending L2",
      "color": "--cl-warn",
      "tint": "--cl-warn-weak",
      "icon": "clock",
      "treatment": "solid"
    },
    "approved": {
      "label": "Approved",
      "color": "--cl-pos",
      "tint": "--cl-pos-weak",
      "icon": "check",
      "treatment": "solid"
    },
    "paid": {
      "label": "Paid",
      "color": "--cl-paid",
      "tint": "--cl-paid-weak",
      "icon": "arrow-right-circle",
      "treatment": "solid"
    },
    "reconciled": {
      "label": "Reconciled",
      "color": "--cl-recon",
      "tint": "--cl-recon-weak",
      "icon": "double-check",
      "treatment": "solid"
    },
    "rejected": {
      "label": "Rejected",
      "color": "--cl-neg",
      "tint": "--cl-neg-weak",
      "icon": "x-circle",
      "treatment": "solid",
      "terminal": true
    },
    "reversed": {
      "label": "Reversed",
      "color": "--cl-warn",
      "tint": "--cl-warn-weak",
      "icon": "arrow-left",
      "treatment": "solid",
      "terminal": true
    },
    "frozen": {
      "label": "Frozen",
      "color": "--cl-text-2",
      "tint": "--cl-surface-2",
      "icon": "snowflake",
      "treatment": "outlined",
      "terminal": true
    },
    "under-review": {
      "label": "Under review",
      "color": "--cl-pending",
      "tint": "--cl-pending-weak",
      "icon": "clock",
      "treatment": "solid"
    }
  },

  "component": {
    "$note": "Tier 3 — component-scoped tokens that resolve to semantic tokens. Change once here to retheme a whole component class.",
    "button": {
      "primary-bg": "--cl-accent",
      "primary-bg-hover": "--cl-accent-2",
      "primary-fg": "#ffffff",
      "secondary-bg": "--cl-surface",
      "secondary-border": "--cl-border-2",
      "secondary-fg": "--cl-text-2",
      "danger-fg": "--cl-neg",
      "disabled-bg": "--cl-surface-2",
      "disabled-fg": "--cl-text-3",
      "radius": "md",
      "height-sm": 34,
      "height-md": 38,
      "hitTarget": 44
    },
    "badge": {
      "radius": "sm",
      "pad-x": 11,
      "pad-y": 5,
      "font-size": 12,
      "font-weight": 600,
      "gap": 6,
      "icon-size": 12
    },
    "table": {
      "header-bg": "--cl-inset",
      "row-selected-bg": "--cl-accent-weak",
      "row-border": "--cl-border",
      "row-height-comfortable": 44,
      "row-height-compact": 34,
      "selection-bar-bg": "--cl-accent"
    },
    "input": {
      "bg": "--cl-surface",
      "border": "--cl-border-2",
      "border-focus": "--cl-accent",
      "border-error": "--cl-neg",
      "focus-ring": "0 0 0 3px var(--cl-accent-weak)",
      "radius": "lg"
    },
    "card": {
      "bg": "--cl-surface",
      "border": "--cl-border",
      "radius": "3xl",
      "pad": 16
    }
  },

  "typography": {
    "family": { "ui": "'Geist', system-ui, sans-serif", "mono": "'Geist Mono', monospace" },
    "features": "tabular-nums",
    "scale": {
      "display": { "size": 34, "weight": 600, "letterSpacing": "-0.02em", "family": "ui" },
      "title": { "size": 22, "weight": 600, "letterSpacing": "-0.01em", "family": "ui" },
      "heading": { "size": 16, "weight": 600, "letterSpacing": "0", "family": "ui" },
      "body": { "size": 14, "weight": 400, "line": 1.45, "family": "ui" },
      "label": { "size": 12.5, "weight": 500, "family": "ui" },
      "mono": {
        "size": 11.5,
        "weight": 400,
        "letterSpacing": "0.02em",
        "family": "mono",
        "tabularNums": true
      }
    }
  },

  "spacing": {
    "base": 4,
    "scale": [4, 6, 8, 10, 12, 14, 18, 22, 32, 40, 56],
    "rowHeight": 44,
    "cardPadding": 16,
    "sectionGap": 56,
    "hitTargetMobile": 44
  },

  "radii": { "sm": 5, "md": 7, "lg": 8, "xl": 11, "2xl": 12, "3xl": 14, "pill": 999 },

  "a11y": {
    "minContrastText": 4.5,
    "focusRing": "3px solid var(--cl-focus)",
    "minTouchTargetPx": 44,
    "statusEncoding": "icon + text + color (never color alone)",
    "grayscaleTest": "Every signal and workflow state remains distinguishable with hue removed, via its glyph and shape."
  }
}
