# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
out/
storybook-static/
# Compiled JS/declarations some lib builds (tsc without an outDir) emit next to their TS source,
# e.g. libs/contracts/src — never source, always regenerated by the build.
libs/**/src/**/*.js
libs/**/src/**/*.d.ts

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store

# Editor
.vscode/
.idea/
.history/

# Misc
*.tsbuildinfo
.cache/

# Monorepo (Nx + pnpm)
.nx/cache
.nx/workspace-data
.nx/migrate-runs
coverage/
.pnpm-store/

# Playwright
playwright-report/
test-results/
blob-report/

