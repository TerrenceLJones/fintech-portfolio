# =====================================================
# CLEARLINE WEB — PRODUCTION ENVIRONMENT VARIABLES
# =====================================================
# App: clearline-web
# Location: apps/clearline-web/
# Epic: PLATFORM-001
# =====================================================
# Set these in Vercel → clearline-web Project → Settings → Environment
# Variables (Production scope). Do not commit real values to git.
# =====================================================

# -----------------------------------------------------
# MONITORING — Sentry (error tracking)
# -----------------------------------------------------
SENTRY_DSN=https://<key>@<org>.ingest.us.sentry.io/<project_id>
# Use the SAME DSN value as configured for Preview deployments, unless a
# separate Sentry environment/project is later set up to split prod vs.
# preview error streams (not done at platform baseline).

