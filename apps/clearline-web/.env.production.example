# =====================================================
# CLEARLINE WEB — PRODUCTION ENVIRONMENT VARIABLES
# =====================================================
# App: clearline-web
# Location: apps/clearline-web/
# Epic: PLATFORM-001
# =====================================================
# Set these in Vercel → clearline-web Project → Settings → Environment
# Variables (Production scope). Do not commit real values to git.
# =====================================================

# -----------------------------------------------------
# DEMO MODE — MSW mock backend + on-screen demo guide
# -----------------------------------------------------
# Set to "true" ONLY on a stakeholder-facing demo/preview deployment. It turns on the MSW mock
# backend (no real API) and the page-aware demo guide widget so viewers can explore the app with
# seeded data. Leave UNSET/absent on any real production deployment — the entire demo/mock code
# path (including the guide chunk) then stays dormant. See apps/clearline-web/src/dev/demo-mode.ts.
# VITE_ENABLE_MOCKS=true

# -----------------------------------------------------
# MONITORING — Sentry (error tracking)
# -----------------------------------------------------
VITE_SENTRY_DSN=https://<key>@<org>.ingest.us.sentry.io/<project_id>
# Use the SAME DSN value as configured for Preview deployments, unless a
# separate Sentry environment/project is later set up to split prod vs.
# preview error streams (not done at platform baseline).

# -----------------------------------------------------
# See TDR-PLATFORM-001.yaml for why these providers were selected
# -----------------------------------------------------
